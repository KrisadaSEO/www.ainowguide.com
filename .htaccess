Options -Indexes
AddDefaultCharset UTF-8
RewriteEngine On

# Canonical domain: force HTTPS + www
# Redirect non-www to www (HTTP or HTTPS)
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.ainowguide.com%{REQUEST_URI} [R=301,L]

# Redirect www HTTP to www HTTPS
RewriteCond %{HTTP_HOST} ^www\.ainowguide\.com$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://www.ainowguide.com%{REQUEST_URI} [R=301,L]

# Static assets
# /assets/* -> public/assets/*  (CSS, JS, images)
RewriteRule ^assets/(.*)$ public/assets/$1 [L,NC]

# /feeds/* -> public/feeds/*
RewriteRule ^feeds/(.*)$ public/feeds/$1 [L,NC]

# AI / federation endpoints
# /ai/* are real files -> serve them directly, no rewrite needed.

# PHP routing
# Pass all other non-file, non-directory requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Security
# Block direct access to config, content, templates, scripts
RewriteRule ^(config|content|templates|scripts|storage|deploy|docs|downloads)/.*$ - [F,L]

# Block dotfiles (except .htaccess itself)
RewriteRule (^|/)\.(?!htaccess) - [F,L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
