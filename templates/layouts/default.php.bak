<?php
// Updated default layout to use partials
$view = $view ?? [];
$record = $view['record'] ?? [];
$title = $view['title'] ?? 'Krisada.com';
$description = $view['description'] ?? '';
$sidebarBlocks = $view['sidebar_blocks'] ?? [];
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($title) ?></title>
    <meta name="description" content="<?= htmlspecialchars($description) ?>">
    <link rel="stylesheet" href="/assets/css/style.css">
    <?php if (!empty($view['canonical_url'])): ?>
    <link rel="canonical" href="<?= htmlspecialchars($view['canonical_url']) ?>">
    <?php endif; ?>
    <style>:root { <?= site_tokens_css() ?> }</style>
</head>
<body>
    <header>
        <h1><a href="/">Krisada.com</a></h1>
        <nav>
            <a href="/library/">Library</a> |
            <a href="/directory/">Directory</a>
        </nav>
    </header>
    <main style="display: flex; gap: 2rem;">
        <section style="flex: 3;">
            <h2><?= htmlspecialchars($title) ?></h2>
            <?php 
            $templatePath = $view['template_path'] ?? null;
            if ($templatePath && file_exists($templatePath)) {
                include $templatePath;
            } else {
                if (!empty($record['body'])) {
                    echo '<div>' . $record['body'] . '</div>';
                } elseif (!empty($record['intro'])) {
                    echo '<div>' . nl2br(htmlspecialchars($record['intro'])) . '</div>';
                } elseif (!empty($record['description'])) {
                    echo '<div>' . nl2br(htmlspecialchars($record['description'])) . '</div>';
                }
            }
            ?>
        </section>
        <aside style="flex: 1;">
            <?php foreach ($sidebarBlocks as $block): ?>
                <?php include site_root_path('templates/partials/sidebar-block.php'); ?>
            <?php endforeach; ?>
        </aside>
    </main>
    <footer>
        <small>&copy; <?= date('Y') ?> Krisada.com</small>
    </footer>
    <?php if (!empty($view['json_ld'])): ?>
    <script type="application/ld+json">
        <?= json_encode($view['json_ld'], JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT) ?>
    </script>
    <?php endif; ?>
</body>
</html>
